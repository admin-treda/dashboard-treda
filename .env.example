# ============================================
# Hermes Allen - Environment Configuration
# Treda Solutions
# ============================================

# General
NODE_ENV=production
API_PORT=3000

# PostgreSQL Database
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hermes_allen
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# Redis
REDIS_URL=redis://redis:6379

# JWT Authentication
JWT_SECRET=change-me-super-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# SMTP / Email Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Branding Colors
BRAND_PRIMARY_NAVY=#21286C
BRAND_ACCENT_CYAN=#00F5B8
BRAND_SECONDARY_BLUE=#5B78FF
BRAND_SOFT_BLUE=#E8F0FE
