generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  name      String
  email     String   @unique
  password  String
  role      Role     @default(viewer)
  mfaSecret String?  @map("mfa_secret")
  mfaEnabled Boolean @default(false) @map("mfa_enabled")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

enum Role {
  admin
  analyst
  viewer
}

model Account {
  id          String   @id @default(uuid())
  name        String
  provider    Provider
  credentials String
  status      Status   @default(active)
  health      Health   @default(healthy)
  region      String?
  createdAt   DateTime @default(now()) @map("created_at")

  events     Event[]
  costs      Cost[]
  costAlerts CostAlert[]

  @@map("accounts")
}

enum Provider {
  AWS
  AZURE
  M365
}

enum Status {
  active
  inactive
  suspended
}

enum Health {
  healthy
  warning
  critical
}

model Event {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  provider    Provider
  type        String
  severity    Severity
  description String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([severity])
  @@index([createdAt])
  @@map("events")
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model Cost {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  service   String
  amount    Decimal  @db.Decimal(18, 2)
  currency  String   @default("USD")
  period    String
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, service, period], name: "idx_costs_unique")
  @@index([accountId])
  @@index([period])
  @@map("costs")
}

model CostAlert {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  threshold   Decimal  @db.Decimal(18, 2)
  currentCost Decimal  @map("current_cost") @db.Decimal(18, 2)
  budget      Decimal  @db.Decimal(18, 2)
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("cost_alerts")
}

model NotificationChannel {
  id        String      @id @default(uuid())
  type      ChannelType
  name      String
  config    Json        @default("{}")
  enabled   Boolean     @default(true)
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("notification_channels")
}

enum ChannelType {
  SMTP
  TELEGRAM
}

model Report {
  id          String       @id @default(uuid())
  type        ReportType
  status      ReportStatus @default(pending)
  data        Json         @default("{}")
  periodStart DateTime?    @map("period_start")
  periodEnd   DateTime?    @map("period_end")
  generatedAt DateTime     @default(now()) @map("generated_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("reports")
}

enum ReportType {
  DAILY
  WEEKLY
}

enum ReportStatus {
  pending
  generating
  completed
  failed
}

model News {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  url         String
  source      String
  category    String   @default("general")
  publishedAt DateTime @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([publishedAt])
  @@index([category])
  @@map("news")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  username  String
  action    String
  resource  String
  detail    Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model PentestScan {
  id             String     @id @default(uuid())
  url            String
  userId         String?    @map("user_id")
  username       String?    @default("")
  status         ScanStatus @default(pending)
  profile        String     @default("balanced")
  targetId       String?    @map("target_id")
  authType       String?    @default("") @map("auth_type")
  authValue      String?    @default("") @map("auth_value")
  phase          String     @default("init")
  phaseLabel     String     @default("Inicialización") @map("phase_label")
  progress       Int        @default(0)
  startedAt      DateTime   @default(now()) @map("started_at")
  finishedAt     DateTime?  @map("finished_at")
  error          String?
  summary        Json       @default("{}")
  openPorts      Json       @default("[]") @map("open_ports")
  subdomains     Json       @default("[]")
  technologies   Json       @default("[]")
  discoveredUrls Json       @default("[]") @map("discovered_urls")
  sslInfo        Json?      @map("ssl_info")
  wafInfo        Json?      @map("waf_info")
  createdAt      DateTime   @default(now()) @map("created_at")

  results        PentestResult[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("pentest_scans")
}

model PentestResult {
  id          String   @id @default(uuid())
  scanId      String   @map("scan_id")
  template    String
  name        String
  severity    String
  tool        String
  type        String   @default("")
  host        String   @default("")
  matchedAt   String   @default("") @map("matched_at")
  description String   @default("")
  reference   Json     @default("[]")
  tags        Json     @default("[]")
  curl        String   @default("")
  request     String   @default("")
  response    String   @default("")
  status      String   @default("open")
  createdAt   DateTime @default(now()) @map("created_at")

  scan        PentestScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([severity])
  @@index([status])
  @@map("pentest_results")
}

enum ScanStatus {
  pending
  running
  queued
  completed
  error
  cancelled
}

model PentestTarget {
  id          String   @id @default(uuid())
  name        String
  url         String
  tags        Json     @default("[]")
  authType    String?  @default("") @map("auth_type")
  authValue   String?  @default("") @map("auth_value")
  notes       String?  @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("pentest_targets")
}

model PentestSchedule {
  id          String   @id @default(uuid())
  targetId    String?  @map("target_id")
  url         String
  profile     String   @default("balanced")
  authType    String?  @default("") @map("auth_type")
  authValue   String?  @default("") @map("auth_value")
  cron        String
  enabled     Boolean  @default(true)
  lastRun     DateTime? @map("last_run")
  nextRun     DateTime? @map("next_run")
  userId      String?  @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([enabled])
  @@index([nextRun])
  @@map("pentest_schedules")
}

model PentestTemplate {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  profile     String   @default("balanced")
  authType    String?  @default("") @map("auth_type")
  authValue   String?  @default("") @map("auth_value")
  tags        Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([name])
  @@map("pentest_templates")
}

model PentestAuditLog {
  id        String   @id @default(uuid())
  scanId    String?  @map("scan_id")
  userId    String?  @map("user_id")
  username  String   @default("")
  action    String
  detail    Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scanId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("pentest_audit_logs")
}
