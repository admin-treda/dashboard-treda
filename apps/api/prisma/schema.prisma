generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  name       String
  email      String   @unique
  password   String
  role       Role     @default(viewer)
  mfaSecret  String?  @map("mfa_secret")
  mfaEnabled Boolean  @default(false) @map("mfa_enabled")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("users")
}

enum Role {
  admin
  analyst
  viewer
}

model Account {
  id          String   @id @default(uuid())
  name        String
  provider    Provider
  credentials String
  status      Status   @default(active)
  health      Health   @default(healthy)
  region      String?
  createdAt   DateTime @default(now()) @map("created_at")

  events     Event[]
  costs      Cost[]
  costAlerts CostAlert[]

  @@map("accounts")
}

enum Provider {
  AWS
  AZURE
  M365
}

enum Status {
  active
  inactive
  suspended
}

enum Health {
  healthy
  warning
  critical
}

model Event {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  provider    Provider
  type        String
  severity    Severity
  description String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([severity])
  @@index([createdAt])
  @@map("events")
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model Cost {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  service   String
  amount    Decimal  @db.Decimal(18, 2)
  currency  String   @default("USD")
  period    String
  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, service, period], name: "idx_costs_unique")
  @@index([accountId])
  @@index([period])
  @@map("costs")
}

model CostAlert {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  threshold   Decimal  @db.Decimal(18, 2)
  currentCost Decimal  @map("current_cost") @db.Decimal(18, 2)
  budget      Decimal  @db.Decimal(18, 2)
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("cost_alerts")
}

model NotificationChannel {
  id        String      @id @default(uuid())
  type      ChannelType
  name      String
  config    Json        @default("{}")
  enabled   Boolean     @default(true)
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("notification_channels")
}

enum ChannelType {
  SMTP
  TELEGRAM
}

model Report {
  id          String       @id @default(uuid())
  type        ReportType
  status      ReportStatus @default(pending)
  data        Json         @default("{}")
  periodStart DateTime?    @map("period_start")
  periodEnd   DateTime?    @map("period_end")
  generatedAt DateTime     @default(now()) @map("generated_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("reports")
}

enum ReportType {
  DAILY
  WEEKLY
}

enum ReportStatus {
  pending
  generating
  completed
  failed
}

model ReportDelivery {
  id         String    @id @default(uuid())
  enabled    Boolean   @default(false)
  channelIds Json      @default("[]") @map("channel_ids")
  schedule   String    @default("0 8 * * *")
  includePdf Boolean   @default(true) @map("include_pdf")
  reportType String    @default("DAILY") @map("report_type")
  lastSentAt DateTime? @map("last_sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("report_delivery")
}

model News {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  url         String
  source      String
  category    String   @default("general")
  publishedAt DateTime @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([publishedAt])
  @@index([category])
  @@map("news")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  username  String
  action    String
  resource  String
  detail    Json?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model PentestScan {
  id             String     @id @default(uuid())
  url            String
  userId         String?    @map("user_id")
  username       String?    @default("")
  status         ScanStatus @default(pending)
  profile        String     @default("balanced")
  targetId       String?    @map("target_id")
  authType       String?    @default("") @map("auth_type")
  authValue      String?    @default("") @map("auth_value")
  phase          String     @default("init")
  phaseLabel     String     @default("Inicialización") @map("phase_label")
  progress       Int        @default(0)
  startedAt      DateTime   @default(now()) @map("started_at")
  finishedAt     DateTime?  @map("finished_at")
  error          String?
  summary        Json       @default("{}")
  openPorts      Json       @default("[]") @map("open_ports")
  subdomains     Json       @default("[]")
  technologies   Json       @default("[]")
  discoveredUrls Json       @default("[]") @map("discovered_urls")
  sslInfo        Json?      @map("ssl_info")
  wafInfo        Json?      @map("waf_info")
  createdAt      DateTime   @default(now()) @map("created_at")

  results PentestResult[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("pentest_scans")
}

model PentestResult {
  id          String   @id @default(uuid())
  scanId      String   @map("scan_id")
  template    String
  name        String
  severity    String
  tool        String
  type        String   @default("")
  host        String   @default("")
  matchedAt   String   @default("") @map("matched_at")
  description String   @default("")
  reference   Json     @default("[]")
  tags        Json     @default("[]")
  curl        String   @default("")
  request     String   @default("")
  response    String   @default("")
  status      String   @default("open")
  createdAt   DateTime @default(now()) @map("created_at")

  scan PentestScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([severity])
  @@index([status])
  @@map("pentest_results")
}

enum ScanStatus {
  pending
  running
  queued
  completed
  error
  cancelled
}

model PentestTarget {
  id        String   @id @default(uuid())
  name      String
  url       String
  tags      Json     @default("[]")
  authType  String?  @default("") @map("auth_type")
  authValue String?  @default("") @map("auth_value")
  notes     String?  @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("pentest_targets")
}

model PentestSchedule {
  id        String    @id @default(uuid())
  targetId  String?   @map("target_id")
  url       String
  profile   String    @default("balanced")
  authType  String?   @default("") @map("auth_type")
  authValue String?   @default("") @map("auth_value")
  cron      String
  enabled   Boolean   @default(true)
  lastRun   DateTime? @map("last_run")
  nextRun   DateTime? @map("next_run")
  userId    String?   @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([enabled])
  @@index([nextRun])
  @@map("pentest_schedules")
}

model PentestTemplate {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  profile     String   @default("balanced")
  authType    String?  @default("") @map("auth_type")
  authValue   String?  @default("") @map("auth_value")
  tags        Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([name])
  @@map("pentest_templates")
}

model PentestAuditLog {
  id        String   @id @default(uuid())
  scanId    String?  @map("scan_id")
  userId    String?  @map("user_id")
  username  String   @default("")
  action    String
  detail    Json?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([scanId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("pentest_audit_logs")
}

// ═══════════════════════════════════════════════════════════════
// ISO 27001:2022 - Sistema de Gestión de Seguridad de la Información
// ═══════════════════════════════════════════════════════════════

model ISMSDashboard {
  id                   String    @id @default(uuid())
  businessUnitId       String?   @map("business_unit_id")
  scope                String    @default("")
  context              Json      @default("{}")
  interestedParties    Json      @default("[]") @map("interested_parties")
  policyUrl            String?   @map("policy_url")
  policyVersion        String?   @map("policy_version")
  policyApprovedAt     DateTime? @map("policy_approved_at")
  policyApprovedBy     String?   @map("policy_approved_by")
  overallCompliance    Float     @default(0) @map("overall_compliance")
  lastManagementReview DateTime? @map("last_management_review")
  nextAuditDate        DateTime? @map("next_audit_date")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  @@index([businessUnitId])
  @@map("isms_dashboard")
}

model Risk {
  id              String          @id @default(uuid())
  businessUnitId  String?         @map("business_unit_id")
  title           String
  description     String          @default("")
  category        RiskCategory
  assetId         String?         @map("asset_id")
  likelihood      Int             @default(1) // 1-5
  impact          Int             @default(1) // 1-5
  riskScore       Int             @default(0) @map("risk_score")
  riskLevel       RiskLevel       @default(LOW) @map("risk_level")
  treatmentOption TreatmentOption @default(MITIGATE) @map("treatment_option")
  treatmentPlan   String?         @map("treatment_plan")
  residualRisk    Int?            @map("residual_risk")
  status          RiskStatus      @default(OPEN)
  owner           String          @default("")
  dueDate         DateTime?       @map("due_date")
  mitigatedAt     DateTime?       @map("mitigated_at")
  notes           String?         @default("")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  @@index([businessUnitId])
  @@index([riskLevel])
  @@index([status])
  @@map("risks")
}

enum RiskCategory {
  STRATEGIC
  OPERATIONAL
  FINANCIAL
  COMPLIANCE
  TECHNICAL
  PHYSICAL
  HUMAN
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TreatmentOption {
  MITIGATE
  TRANSFER
  ACCEPT
  AVOID
}

enum RiskStatus {
  OPEN
  IN_PROGRESS
  MITIGATED
  ACCEPTED
  TRANSFERRED
  CLOSED
}

model SoAControl {
  id                   String               @id @default(uuid())
  businessUnitId       String?              @map("business_unit_id")
  controlId            String               @map("control_id")
  title                String
  description          String               @default("")
  category             SoACategory
  applicable           Boolean              @default(true)
  justification        String?
  implementationStatus ImplementationStatus @default(NOT_IMPLEMENTED) @map("implementation_status")
  implementationNotes  String?              @map("implementation_notes")
  owner                String?
  evidenceIds          Json                 @default("[]") @map("evidence_ids")
  relatedModule        String?              @map("related_module")
  lastReviewed         DateTime?            @map("last_reviewed")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  @@unique([controlId, businessUnitId])
  @@index([businessUnitId])
  @@index([category])
  @@index([implementationStatus])
  @@map("soa_controls")
}

enum SoACategory {
  A5_ORGANIZATIONAL
  A6_PEOPLE
  A7_PHYSICAL
  A8_TECHNOLOGICAL
}

enum ImplementationStatus {
  NOT_IMPLEMENTED
  PARTIAL
  IMPLEMENTED
  NOT_APPLICABLE
}

// ═══════════════════════════════════════════════════════════════
// ISO 27001:2022 - Gestión de Documentos
// ═══════════════════════════════════════════════════════════════

model Document {
  id             String           @id @default(uuid())
  businessUnitId String?          @map("business_unit_id")
  title          String
  type           DocumentType
  category       DocumentCategory
  content        String?          @db.Text
  fileUrl        String?          @map("file_url")
  fileSize       Int?             @map("file_size")
  version        String           @default("1.0")
  status         DocumentStatus   @default(DRAFT)
  owner          String?
  reviewers      Json             @default("[]")
  approvedBy     String?          @map("approved_by")
  approvedAt     DateTime?        @map("approved_at")
  nextReviewDate DateTime?        @map("next_review_date")
  tags           Json             @default("[]")
  relatedSoA     Json             @default("[]") @map("related_soa")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  @@index([businessUnitId])
  @@index([type])
  @@index([status])
  @@index([category])
  @@map("documents")
}

enum DocumentType {
  POLICY
  PROCEDURE
  WORK_INSTRUCTION
  RECORD
  PLAN
  REPORT
  MANUAL
}

enum DocumentCategory {
  INFORMATION_SECURITY
  ACCESS_CONTROL
  CRYPTOGRAPHY
  PHYSICAL_SECURITY
  OPERATIONS_SECURITY
  COMMUNICATIONS_SECURITY
  SYSTEM_ACQUISITION
  SUPPLIER_RELATIONSHIPS
  INCIDENT_MANAGEMENT
  BUSINESS_CONTINUITY
  COMPLIANCE
  HR_SECURITY
  ASSET_MANAGEMENT
  RISK_MANAGEMENT
}

enum DocumentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  OBSOLETE
}

// ═══════════════════════════════════════════════════════════════
// ISO 27001:2022 - Capacitación y Concientización (A.6.3)
// ═══════════════════════════════════════════════════════════════

model TrainingCourse {
  id              String           @id @default(uuid())
  title           String
  description     String           @default("")
  category        TrainingCategory
  durationMinutes Int              @map("duration_minutes")
  required        Boolean          @default(false)
  frequency       String? // annual, quarterly, monthly
  passingScore    Int              @default(80) @map("passing_score")
  soaControls     Json             @default("[]") @map("soa_controls")
  status          CourseStatus     @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  enrollments TrainingEnrollment[]

  @@index([category])
  @@map("training_courses")
}

enum TrainingCategory {
  SECURITY_AWARENESS
  PHISHING
  PASSWORD_SECURITY
  DATA_PROTECTION
  INCIDENT_RESPONSE
  COMPLIANCE
  ROLE_SPECIFIC
  ONBOARDING
  CRYPTOGRAPHY
  ACCESS_CONTROL
}

enum CourseStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model TrainingEnrollment {
  id             String           @id @default(uuid())
  courseId       String           @map("course_id")
  userId         String           @map("user_id")
  userName       String           @default("") @map("user_name")
  status         EnrollmentStatus @default(ENROLLED)
  enrolledAt     DateTime         @default(now()) @map("enrolled_at")
  startedAt      DateTime?        @map("started_at")
  completedAt    DateTime?        @map("completed_at")
  score          Int?
  certificateUrl String?          @map("certificate_url")
  notes          String?          @default("")

  course TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
  @@index([status])
  @@map("training_enrollments")
}

enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  FAILED
  EXPIRED
}

// ═══════════════════════════════════════════════════════════════
// ISO 27001:2022 - Auditorías Internas (9.2)
// ═══════════════════════════════════════════════════════════════

model InternalAudit {
  id              String      @id @default(uuid())
  businessUnitId  String?     @map("business_unit_id")
  title           String
  description     String      @default("")
  auditType       AuditType   @map("audit_type")
  scope           String      @default("")
  criteria        String?     @map("audit_criteria")
  auditorName     String      @map("auditor_name")
  auditDate       DateTime    @map("audit_date")
  status          AuditStatus @default(PLANNED)
  findings        Json        @default("[]")
  nonConformities Int         @default(0) @map("non_conformities")
  opportunities   Int         @default(0)
  positives       Int         @default(0)
  reportUrl       String?     @map("report_url")
  nextAuditDate   DateTime?   @map("next_audit_date")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  @@index([businessUnitId])
  @@index([status])
  @@index([auditDate])
  @@map("internal_audits")
}

enum AuditType {
  FULL_ISO27001
  PARTIAL
  SURVEILLANCE
  FOLLOW_UP
  PRE_CERTIFICATION
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  FOLLOW_UP
  CLOSED
}

// ═══════════════════════════════════════════════════════════════
// ISO 27001:2022 - Acciones Correctivas / CAPA (10.2)
// ═══════════════════════════════════════════════════════════════

model CAPA {
  id               String     @id @default(uuid())
  businessUnitId   String?    @map("business_unit_id")
  title            String
  description      String     @default("")
  type             CAPAType
  source           String     @default("")
  sourceId         String?    @map("source_id")
  rootCause        String?    @map("root_cause")
  correctiveAction String?    @map("corrective_action")
  preventiveAction String?    @map("preventive_action")
  owner            String
  dueDate          DateTime?  @map("due_date")
  status           CAPAStatus @default(OPEN)
  effectiveness    String?
  verifiedBy       String?    @map("verified_by")
  verifiedAt       DateTime?  @map("verified_at")
  closedAt         DateTime?  @map("closed_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  businessUnit BusinessUnit? @relation(fields: [businessUnitId], references: [id])

  @@index([businessUnitId])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@map("capa")
}

enum CAPAType {
  CORRECTIVE
  PREVENTIVE
  IMPROVEMENT
}

enum CAPAStatus {
  OPEN
  IN_PROGRESS
  IMPLEMENTED
  VERIFIED
  CLOSED
  REJECTED
}

// ═══════════════════════════════════════════════════════════════
// UNIDADES DE NEGOCIO — Multi-branch ISO 27001
// ═══════════════════════════════════════════════════════════════

model BusinessUnit {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  industry    String?  @default("")
  logo        String?
  status      BUStatus @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  isms        ISMSDashboard[]
  risks       Risk[]
  soaControls SoAControl[]
  documents   Document[]
  audits      InternalAudit[]
  capas       CAPA[]

  @@map("business_units")
}

enum BUStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}
